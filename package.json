{
	"name": "@bopstack/config",
	"version": "0.1.1",
	"description": "Shared Biome and TypeScript configs plus an init CLI for BopStack projects.",
	"keywords": [
		"bopstack",
		"biome",
		"typescript",
		"config"
	],
	"homepage": "https://github.com/BopStack/config#readme",
	"bugs": {
		"url": "https://github.com/BopStack/config/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/BopStack/config.git"
	},
	"license": "MIT",
	"author": "BopStack (https://github.com/BopStack)",
	"type": "module",
	"bin": {
		"bopstack-config": "./dist/index.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./biome": "./src/config/biome/biome-config.json",
		"./tsconfig/base": "./src/config/tsconfig/base.json",
		"./lint": {
			"types": "./dist/lint/index.d.ts",
			"default": "./dist/lint/index.js"
		},
		"./lint/check-justfile-syntax": {
			"types": "./dist/lint/check_justfile_syntax.d.ts",
			"default": "./dist/lint/check_justfile_syntax.js"
		},
		"./lint/check-no-coauthor": {
			"types": "./dist/lint/check_no_coauthor.d.ts",
			"default": "./dist/lint/check_no_coauthor.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist/",
		"src/config/"
	],
	"engines": {
		"node": ">=20"
	},
	"packageManager": "pnpm@10.0.0",
	"publishConfig": {
		"access": "public"
	},
	"scripts": {},
	"dependencies": {
		"arktype": "^2.2.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"tsx": "^4.22.4",
		"typescript": "^5.9.3",
		"vitest": "^3.2.4"
	}
}
