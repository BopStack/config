{
  "name": "@bopstack/config",
  "version": "0.1.0",
  "description": "CLI for installing @bopstack/* config packages into target projects",
  "license": "MIT",
  "bin": {
    "bopstack-config": "./src/cli/index.ts"
  },
  "files": [
    "src/"
  ],
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "oxfmt --config oxfmtrc.json .",
    "lint": "oxlint .",
    "build": "tsc",
    "check": "oxfmt --config oxfmtrc.json . && oxlint . && tsc --noEmit && vitest run"
  },
  "dependencies": {
    "arktype": "^2.2.0"
  },
  "devDependencies": {
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
