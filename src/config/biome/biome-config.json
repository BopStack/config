{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"domains": {
			"project": "all",
			"types": "all"
		},
		"rules": {
			"recommended": true,
			"correctness": {
				"useImportExtensions": "off",
				"noUnresolvedImports": "off",
				"noUnusedVariables": "error",
				"noUnusedImports": "error",
				"noUnusedFunctionParameters": "error",
				"noUnusedLabels": "error",
				"noUnusedPrivateClassMembers": "error",
				"useExhaustiveDependencies": "error",
				"noUndeclaredDependencies": "error",
				"noNestedComponentDefinitions": "error",
				"noGlobalDirnameFilename": "error",
				"useHookAtTopLevel": "error",
				"useParseIntRadix": "error",
				"noPrivateImports": "error"
			},
			"style": {
				"noNonNullAssertion": "off",
				"noNestedTernary": "error",
				"noUselessElse": "error",
				"noInferrableTypes": "error",
				"useBlockStatements": "error",
				"useCollapsedIf": "error",
				"noMagicNumbers": "error",
				"useConst": "error",
				"useTemplate": "error",
				"noCommonJs": "error",
				"useNodejsImportProtocol": "error",
				"useConsistentTypeDefinitions": {
					"options": {
						"style": "type"
					},
					"level": "error"
				},
				"useExplicitLengthCheck": "error",
				"useShorthandAssign": "error",
				"useDefaultSwitchClause": "error",
				"useSingleVarDeclarator": "error",
				"useDefaultParameterLast": "error",
				"useConsistentArrayType": "error",
				"useNumericSeparators": "error",
				"useFragmentSyntax": "error",
				"noParameterAssign": "error",
				"noYodaExpression": "error",
				"useNodeAssertStrict": "error",
				"useExponentiationOperator": "error",
				"useExportType": "error",
				"useImportType": "error",
				"useNamingConvention": {
					"level": "error",
					"options": {
						"strictCase": false,
						"conventions": [
							{
								"selector": {
									"kind": "const",
									"scope": "global"
								},
								"formats": ["snake_case", "CONSTANT_CASE", "PascalCase"]
							},
							{
								"selector": {
									"kind": "function"
								},
								"formats": ["snake_case"]
							},
							{
								"selector": {
									"kind": "variable"
								},
								"formats": ["snake_case"]
							},
							{
								"selector": {
									"kind": "functionParameter"
								},
								"formats": ["snake_case"]
							},
							{
								"selector": {
									"kind": "typeAlias"
								},
								"formats": ["PascalCase"]
							},
							{
								"selector": {
									"kind": "interface"
								},
								"formats": ["PascalCase"]
							},
							{
								"selector": {
									"kind": "class"
								},
								"formats": ["PascalCase"]
							},
							{
								"selector": {
									"kind": "importNamespace"
								},
								"formats": ["snake_case"]
							},
							{
								"selector": {
									"kind": "objectLiteralProperty"
								},
								"match": ".*"
							},
							{
								"selector": {
									"kind": "typeProperty"
								},
								"match": ".*"
							}
						]
					}
				}
			},
			"suspicious": {
				"noConsole": "error",
				"noExplicitAny": "error",
				"noImportCycles": "error",
				"noEmptyBlockStatements": "error",
				"useErrorMessage": "error",
				"useNumberToFixedDigitsArgument": "error",
				"noVar": "error",
				"noConfusingVoidType": "error",
				"noConstEnum": "error",
				"noTsIgnore": "error",
				"noFocusedTests": "error",
				"noCatchAssign": "error",
				"noIrregularWhitespace": "error",
				"noPrototypeBuiltins": "error",
				"noDocumentCookie": "error",
				"noConfusingLabels": "error",
				"noExtraNonNullAssertion": "error",
				"noOctalEscape": "error",
				"noRedundantUseStrict": "error",
				"noSuspiciousSemicolonInJsx": "error",
				"noTemplateCurlyInString": "error",
				"noUselessEscapeInString": "error",
				"noUselessRegexBackrefs": "error",
				"noApproximativeNumericConstant": "error",
				"noGlobalIsFinite": "error",
				"noGlobalIsNan": "error",
				"useIsArray": "error",
				"useGetterReturn": "error",
				"useDefaultSwitchClauseLast": "error",
				"useAdjacentOverloadSignatures": "error",
				"noAlert": "error",
				"noEmptyInterface": "error",
				"noImplicitAnyLet": "error"
			},
			"complexity": {
				"noForEach": "error",
				"noBannedTypes": "error",
				"noImplicitCoercions": "error",
				"noExcessiveCognitiveComplexity": {
					"level": "error",
					"options": {
						"maxAllowedComplexity": 15
					}
				},
				"noExcessiveLinesPerFunction": {
					"level": "error",
					"options": {
						"maxLines": 80,
						"skipBlankLines": true,
						"skipIifes": true
					}
				},
				"useMaxParams": {
					"level": "error",
					"options": {
						"max": 3
					}
				},
				"noArguments": "error",
				"noCommaOperator": "error",
				"noStaticOnlyClass": "error",
				"noThisInStatic": "error",
				"useArrowFunction": "error",
				"useFlatMap": "error",
				"noUselessLoneBlockStatements": "error",
				"useLiteralKeys": "error",
				"noUselessTernary": "error",
				"noUselessCatch": "error",
				"useOptionalChain": "error",
				"useWhile": "error",
				"useSimplifiedLogicExpression": "error",
				"noAdjacentSpacesInRegex": "error",
				"noEmptyTypeParameters": "error",
				"noExcessiveNestedTestSuites": "error",
				"noExtraBooleanCast": "error",
				"noFlatMapIdentity": "error",
				"noUselessConstructor": "error",
				"noUselessContinue": "error",
				"noUselessEmptyExport": "error",
				"noUselessEscapeInRegex": "error",
				"noUselessFragments": "error",
				"noUselessLabel": "error",
				"noUselessRename": "error",
				"noUselessStringConcat": "error",
				"noUselessStringRaw": "error",
				"noUselessSwitchCase": "error",
				"noUselessThisAlias": "error",
				"noUselessTypeConstraint": "error",
				"noUselessUndefined": "error",
				"noUselessUndefinedInitialization": "error",
				"useDateNow": "error",
				"useIndexOf": "error",
				"useNumericLiterals": "error",
				"useRegexLiterals": "error",
				"useSimpleNumberKeys": "error"
			},
			"security": {
				"noSecrets": "error",
				"noBlankTarget": "error"
			},
			"performance": {
				"noAccumulatingSpread": "error",
				"noBarrelFile": "error",
				"noAwaitInLoops": "error",
				"noDelete": "error",
				"noNamespaceImport": "error",
				"noReExportAll": "error",
				"useTopLevelRegex": "error",
				"noDynamicNamespaceImportAccess": "error"
			},
			"nursery": {
				"noInlineStyles": "error",
				"useSortedClasses": "error",
				"noTernary": "off",
				"useExhaustiveSwitchCases": "error",
				"useAwaitThenable": "error",
				"useErrorCause": "error",
				"useArraySome": "error",
				"useFind": "error",
				"useNullishCoalescing": "error",
				"useStringStartsEndsWith": "error",
				"useGlobalThis": "error",
				"useSpread": "error",
				"useRegexpTest": "error",
				"useRegexpExec": "error",
				"useMathMinMax": "error",
				"useDomQuerySelector": "error",
				"useDomNodeTextContent": "error",
				"noComponentHookFactories": "error",
				"noShadow": "error",
				"noFloatingPromises": "error",
				"noMisusedPromises": "error",
				"noUselessTypeConversion": "error",
				"noExcessiveNestedCallbacks": "error",
				"noExcessiveClassesPerFile": "error",
				"noExcessiveLinesPerFile": {
					"level": "error",
					"options": {
						"maxLines": 400,
						"skipBlankLines": true
					}
				},
				"useExplicitType": "off",
				"useExplicitReturnType": "error",
				"useConsistentTestIt": {
					"level": "error",
					"options": {
						"function": "test",
						"withinDescribe": "test"
					}
				},
				"useConsistentEnumValueType": "error",
				"useDisposables": "error",
				"useConsistentMethodSignatures": "error",
				"noUndeclaredEnvVars": "error",
				"noConditionalExpect": "error",
				"noIdenticalTestTitle": "error",
				"useExpect": "error",
				"useTestHooksInOrder": "error",
				"useTestHooksOnTop": "error",
				"useArraySortCompare": "error",
				"noUnnecessaryConditions": "error",
				"noUnsafePlusOperands": "error",
				"noBaseToString": "error",
				"noDuplicateEnumValues": "error",
				"noForIn": "error",
				"noIncrementDecrement": "error",
				"noJsxPropsBind": "error",
				"noMisleadingReturnType": "error",
				"noNestedPromises": "error",
				"noReturnAssign": "error",
				"noScriptUrl": "error",
				"useDestructuring": "error",
				"useImportsFirst": "error"
			}
		}
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"plugins": [
		"./node_modules/@bopstack/config/src/config/biome/rules/no_inline_if.grit",
		"./node_modules/@bopstack/config/src/config/biome/rules/no_hardcoded_colors.grit",
		"./node_modules/@bopstack/config/src/config/biome/rules/test_naming.grit",
		"./node_modules/@bopstack/config/src/config/biome/rules/prefer_testid.grit",
		"./node_modules/@bopstack/config/src/config/biome/rules/max_nesting_depth.grit",
		"./node_modules/@bopstack/config/src/config/biome/rules/drizzle_fk_index.grit",
		"./node_modules/@bopstack/config/src/config/biome/rules/drizzle_no_relations.grit",
		"./node_modules/@bopstack/config/src/config/biome/rules/no_empty_catch.grit",
		"./node_modules/@bopstack/config/src/config/biome/rules/no_throwing_non_error.grit"
	],
	"javascript": {
		"formatter": {
			"semicolons": "asNeeded",
			"trailingCommas": "all",
			"quoteStyle": "single"
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	}
}
